<section class="container section" style="max-width:420px">
  <h1>Activar cuenta</h1>
  {% form 'activate_customer_password' %}
    {{ form.errors | default_errors }}
    <div class="field"><label>Contraseña<input type="password" name="customer[password]" required></label></div>
    <div class="field"><label>Confirmar<input type="password" name="customer[password_confirmation]" required></label></div>
    <button type="submit" class="btn btn--primary btn--block">Activar</button>
  {% endform %}
</section>