<section class="container section">
  <h1>Mi cuenta</h1>
  <p>Hola {{ customer.first_name }}. <a href="{{ routes.account_logout_url }}">Cerrar sesión</a></p>
  <h2 class="mt-8">Pedidos</h2>
  {% if customer.orders.size > 0 %}
    <table style="width:100%;border-collapse:collapse">
      <thead><tr><th>#</th><th>Fecha</th><th>Total</th><th>Estado</th></tr></thead>
      <tbody>
        {% for order in customer.orders %}
          <tr><td><a href="{{ order.customer_url }}">{{ order.name }}</a></td><td>{{ order.created_at | date: '%d/%m/%Y' }}</td><td>{{ order.total_price | money }}</td><td>{{ order.financial_status_label }}</td></tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p>Aún no tienes pedidos.</p>
  {% endif %}
</section>