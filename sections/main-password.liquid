<div>
  <img src="{{ 'logo-zz.png' | asset_url }}" alt="{{ shop.name }}" width="200" style="filter:brightness(0) invert(1);margin:0 auto 16px">
  <h1>{{ shop.name }}</h1>
  <p>Muy pronto abrimos la tienda.</p>
  {% form 'storefront_password' %}
    <div class="field" style="max-width:320px;margin:16px auto">
      <label for="pw">Contraseña</label>
      <input type="password" name="password" id="pw" required>
    </div>
    <button type="submit" class="btn btn--accent">Entrar</button>
  {% endform %}
</div>
{% schema %}
{ "name": "Password", "settings": [], "enabled_on": { "templates": ["password"] } }
{% endschema %}