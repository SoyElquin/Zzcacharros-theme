<section class="container">
  <div class="product">
    <div class="product__media">
      {% if product.featured_image %}
        {{ product.featured_image | image_url: width: 1200 | image_tag: alt: product.title, loading: 'eager', width: 1200 }}
      {% endif %}
      {% if product.images.size > 1 %}
        <div class="product__thumbs">
          {% for img in product.images limit: 5 %}
            <img src="{{ img | image_url: width: 200 }}" data-full="{{ img | image_url: width: 1200 }}" alt="{{ product.title }}" width="200" height="200" loading="lazy">
          {% endfor %}
        </div>
      {% endif %}
    </div>
    <div class="product__info">
      <h1 class="product__title">{{ product.title }}</h1>
      <div class="product__price" data-price>
        {% if product.compare_at_price > product.price %}<s>{{ product.compare_at_price | money }}</s>{% endif %}
        {{ product.price | money }}
      </div>
      {% form 'product', product %}
        {% if product.variants.size > 1 %}
          <div class="product__variants">
            <label for="variant-select">Variante</label>
            <select id="variant-select" name="id" data-variant-select>
              {% for v in product.variants %}
                <option value="{{ v.id }}" data-price="{{ v.price | money }}" {% if v.available == false %}disabled{% endif %} {% if v == product.selected_or_first_available_variant %}selected{% endif %}>
                  {{ v.title }} — {{ v.price | money }}{% unless v.available %} · Agotado{% endunless %}
                </option>
              {% endfor %}
            </select>
          </div>
        {% else %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {% endif %}
        <div class="mt-4">
          <div class="product__qty">
            <button type="button" data-qty="-1" aria-label="Disminuir">−</button>
            <input type="number" name="quantity" value="1" min="1">
            <button type="button" data-qty="1" aria-label="Aumentar">+</button>
          </div>
          <button type="submit" class="btn btn--primary" {% unless product.available %}disabled{% endunless %}>
            {% if product.available %}Agregar al carrito{% else %}Agotado{% endif %}
          </button>
        </div>
      {% endform %}
      <div class="product__desc">{{ product.description }}</div>
    </div>
  </div>
</section>
{% schema %}
{ "name": "Product", "settings": [], "enabled_on": { "templates": ["product"] } }
{% endschema %}