<section class="container section">
  <h1>Búsqueda</h1>
  <form action="{{ routes.search_url }}" method="get" role="search" style="max-width:520px;margin:16px 0">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Buscar..." style="width:100%;padding:12px;border:1px solid var(--border);border-radius:8px">
  </form>
  {% if search.performed %}
    <p>{{ search.results_count }} resultados</p>
    <div class="grid grid--products mt-4">
      {% for item in search.results %}
        {% if item.object_type == 'product' %}
          {% render 'product-card', product: item %}
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</section>
{% schema %}
{ "name": "Search", "settings": [], "enabled_on": { "templates": ["search"] } }
{% endschema %}