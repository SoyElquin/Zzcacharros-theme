{% if section.settings.text != blank %}
  <div class="announcement">{{ section.settings.text }}</div>
{% endif %}
{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "text", "id": "text", "label": "Text", "default": "🚚 Envío gratis en compras superiores a $150.000" }
  ],
  "presets": [ { "name": "Announcement bar" } ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}