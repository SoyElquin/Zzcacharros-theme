<section class="section">
  <div class="container">
    <div class="section__head">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.collection != blank %}
        <a class="btn btn--ghost" href="{{ collections[section.settings.collection].url }}">Ver todo</a>
      {% endif %}
    </div>
    <div class="grid grid--products">
      {% assign col = collections[section.settings.collection] %}
      {% for product in col.products limit: section.settings.limit %}
        {% render 'product-card', product: product %}
      {% else %}
        <p>Aún no hay productos.</p>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Destacados" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "min": 4, "max": 24, "step": 4, "default": 8, "label": "Products to show" }
  ],
  "presets": [ { "name": "Featured collection" } ]
}
{% endschema %}