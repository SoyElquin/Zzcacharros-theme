<section class="container section">
  <h1>{{ collection.title }}</h1>
  {% if collection.description != blank %}<p style="max-width:720px">{{ collection.description }}</p>{% endif %}
  {% paginate collection.products by 24 %}
    <div class="grid grid--products mt-4">
      {% for product in collection.products %}
        {% render 'product-card', product: product %}
      {% else %}
        <p>Aún no hay productos en esta colección.</p>
      {% endfor %}
    </div>
    {% if paginate.pages > 1 %}
      <nav class="mt-8 text-center">{{ paginate | default_pagination }}</nav>
    {% endif %}
  {% endpaginate %}
</section>
{% schema %}
{ "name": "Collection", "settings": [], "enabled_on": { "templates": ["collection"] } }
{% endschema %}