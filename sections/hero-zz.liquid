{%- assign wa = settings.whatsapp_number -%}
<section class="hero">
  <div class="hero__wrap">
    {% if section.settings.hero_image %}
      {{ section.settings.hero_image | image_url: width: 1600 | image_tag: alt: 'Zzcacharros - Tu almacén favorito ahora online', class: 'hero__img', loading: 'eager', width: 1600, height: 1200 }}
    {% else %}
      <img class="hero__img" src="{{ 'hero-zz.jpg' | asset_url }}" alt="Zzcacharros - Tu almacén favorito ahora online" width="1600" height="1200" loading="eager">
    {% endif %}
  </div>
  <div class="hero__ctas">
    <div class="hero__ctas-inner">
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--yellow btn--lg">
        Ver catálogo →
      </a>
      <a href="https://wa.me/{{ wa }}?text=Hola%20Zzcacharros,%20quiero%20información" target="_blank" rel="noopener" class="btn btn--green btn--lg">
        💬 Pedir por WhatsApp
      </a>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Hero Zz",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Imagen hero (yellow bg)" }
  ],
  "presets": [{ "name": "Hero Zz" }]
}
{% endschema %}
