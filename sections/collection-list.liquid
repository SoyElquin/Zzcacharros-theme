<section class="section">
  <div class="container">
    <div class="section__head">
      <h2>{{ section.settings.heading }}</h2>
      <a class="btn btn--ghost" href="{{ routes.collections_url }}">Ver todas</a>
    </div>
    <div class="grid grid--cats">
      {% for block in section.blocks %}
        {% assign col = collections[block.settings.collection] %}
        {% if col != blank %}
          <a class="cat-card" href="{{ col.url }}" {{ block.shopify_attributes }}>
            {% if col.image %}
              {{ col.image | image_url: width: 400 | image_tag: alt: col.title, loading: 'lazy', width: 400, height: 400 }}
            {% elsif col.featured_image %}
              {{ col.featured_image | image_url: width: 400 | image_tag: alt: col.title, loading: 'lazy', width: 400, height: 400 }}
            {% else %}
              <img src="{{ 'logo-zz.png' | asset_url }}" alt="{{ col.title }}" loading="lazy">
            {% endif %}
            <span class="cat-card__label">{{ col.title }}</span>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Collection list",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Categorías" }
  ],
  "blocks": [
    { "type": "collection", "name": "Collection", "settings": [ { "type": "collection", "id": "collection", "label": "Collection" } ] }
  ],
  "max_blocks": 24,
  "presets": [ { "name": "Collection list", "blocks": [ { "type": "collection" }, { "type": "collection" }, { "type": "collection" }, { "type": "collection" } ] } ]
}
{% endschema %}